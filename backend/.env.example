# Ilova nomi
APP_NAME=FaceID Verification API
API_V1_PREFIX=/api/v1

# JWT sozlamalari
# MUHIM: Production'da SECRET_KEY ni hech qachon qayta ishlatmang.
# Yaratish: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME__generate_with_secrets.token_urlsafe_48
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token
REFRESH_TOKEN_EXPIRE_DAYS=7

# API kalit hashlash uchun alohida pepper (SECRET_KEY bilan bog'liq emas).
# Rotatsiya: mavjud API kalitlarini bekor qilib, yangi pepper bilan qayta yaratish kerak.
API_KEY_PEPPER=CHANGE_ME__generate_with_secrets.token_urlsafe_48

# Database (dev default, production'da kuchli parol ishlatish)
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/faceid_db

# Rasm tekshiruv parametrlari
MAX_BASE64_SIZE=5242880
MIN_WIDTH=200
MAX_WIDTH=500
MIN_HEIGHT=250
MAX_HEIGHT=600
MIN_PALITRA_VALUE=0
AGE_TOLERANCE=10
SIMILARITY_THRESHOLD=0.45
BG_COLOR_THRESHOLD=100

# Rasm saqlash
UPLOADS_PHOTO_DIR=uploads/verifications
UPLOADS_FACE_DIR=uploads/faces
THUMBNAIL_SIZE=150
WEBP_QUALITY=80

# ML Inference
MAX_CONCURRENT_INFERENCE=8
INFERENCE_TIMEOUT_SECONDS=30
FACE_DET_SIZE=320
FACE_DET_THRESH=0.3

# Celery / Redis
REDIS_URL=redis://127.0.0.1:6379/0
TASK_RESULT_TTL=3600

# Cookie (production HTTPS orqasida: true)
COOKIE_SECURE=true

# CORS (production domeningizni kiriting)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Tashqi API (URLlar public bo'lishi mumkin, lekin tokenlar hech qachon repo'ga kirmaydi)
API_CEFR=
API_MS=
API_IIV=
API_IIV_TOKEN=
API_GTSP=
