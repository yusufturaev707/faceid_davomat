# Telegram bot tokeni (@BotFather dan olinadi)
BOT_TOKEN=

# FaceID backend (FastAPI) manzili — /api/v1 bilan tugaydi.
# Masalan prod: https://face-id.uzbmb.uz/api/v1
API_BASE_URL=http://localhost:8000/api/v1

# Admin panelda yaratilgan API kalit (X-API-Key headerida yuboriladi).
API_KEY=

# Backend so'rovlari uchun timeout (soniya).
REQUEST_TIMEOUT=30

# === Quyidagilar faqat backend seed skripti uchun ===
# (cd backend && python -m app.db.seed_statistic_bot)
# ADMIN_IDS → role=1 (Admin), STAFF_IDS → role=3 (Xodim).
# Seed bir martalik; keyin foydalanuvchilar admin panel orqali boshqariladi.
# ADMIN_IDS=928011290,475410002,617434797,454019159,132947970
# STAFF_IDS=
