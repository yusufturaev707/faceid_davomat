# Telegram bot tokeni (@BotFather dan olinadi)
BOT_TOKEN=

# Tashqi API manzili (statistika qaytaradigan endpoint)
API_URL=https://example.uz/api/statistics

# API token (ixtiyoriy). Agar to'ldirilsa: Authorization: <token> (xom, Bearer'siz) yuboriladi
API_TOKEN=

# Statistikani ko'ra oladigan adminlar (vergul bilan ajratilgan Telegram ID lar)
ADMIN_IDS=928011290,475410002,617434797,454019159,132947970

# Xodimlar — oddiy statistikadan tashqari 2025-yil bloki ham ko'rinadi.
# Xodim avtomatik admin huquqiga ega (ADMIN_IDS ga qo'shish shart emas).
STAFF_IDS=

# API javobini necha soniya kesh saqlash (so'rovlarni kamaytirish uchun)
CACHE_TTL=60
